# Conexion a PostgreSQL local (ajustar usuario/contraseña/puerto según tu instalación)
DATABASE_URL="postgresql://postgres:2535@localhost:5432/notisability_backend_db?schema=public"

# Configuración del servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET="cambia_este_secreto_de_acceso"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="cambia_este_secreto_de_refresco"
JWT_REFRESH_EXPIRES_IN="30d"

# URL pública del backend (usada para el webhook de Mercado Pago)
BACKEND_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# Mercado Pago (back_urls deben apuntar al frontend)
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MP_SUCCESS_URL="http://localhost:5173/checkout/success"
MP_FAILURE_URL="http://localhost:5173/checkout/failure"
MP_PENDING_URL="http://localhost:5173/checkout/pending"

# Archivos
UPLOADS_DIR="uploads"
