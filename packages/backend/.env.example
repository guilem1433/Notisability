# --- Base de datos ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/notisability?schema=public"

# --- Servidor ---
PORT=4000
NODE_ENV=development
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:5173"

# --- Autenticacion (JWT) ---
JWT_ACCESS_SECRET="change-this-access-secret"
JWT_REFRESH_SECRET="change-this-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
BCRYPT_SALT_ROUNDS=10

# --- Mercado Pago ---
# Access token privado de la cuenta vendedora (Test o Produccion)
MP_ACCESS_TOKEN="TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000"
# Clave secreta usada para validar la firma "x-signature" de los webhooks
MP_WEBHOOK_SECRET="change-this-webhook-secret"

# --- Almacenamiento de archivos digitales ---
FILES_STORAGE_PATH="./storage/products"
MAX_FILE_SIZE_MB=200
